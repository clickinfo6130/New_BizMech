# ─────────────────────────────────────────────────────────
# BizMech environment variables
# Copy to `.env.local` (gitignored) to override defaults.
# ─────────────────────────────────────────────────────────

# API mode:
#   'mock' → MockPartApi (sql.js, reads /public/data/*.db in the browser)
#   'http' → HttpPartApi (Axios → bizmech-proxy or Java backend)
VITE_API_MODE=mock

# When VITE_API_MODE=http, base URL of the REST backend.
# Point at the Node.js proxy during development:
#   VITE_API_BASE_URL=http://localhost:8080/api
# Or the LAN-accessible proxy:
#   VITE_API_BASE_URL=http://192.168.0.17:8080/api
# Or eventually the Java backend.
VITE_API_BASE_URL=http://localhost:8080/api

# Default language (ko|en|ja|zh)
VITE_DEFAULT_LANG=ko
