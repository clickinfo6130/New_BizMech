# ─────────────────────────────────────────────────────────
# BizMech Proxy — PostgreSQL connection to Spec server
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` to git.
# ─────────────────────────────────────────────────────────

# Proxy HTTP server
PORT=8080
CORS_ORIGIN=http://localhost:5173

# PostgreSQL connection (Spec server)
PG_HOST=192.168.0.17
PG_PORT=5432
PG_USER=<fill me>
PG_PASSWORD=<fill me>

# ─────────────────────────────────────────────────────────
# DATABASE REGISTRY  ★ 새 DB 추가는 여기 한 줄만 수정 ★
# ─────────────────────────────────────────────────────────
# Per-category PostgreSQL databases (case-sensitive). To add a new
# category (Cylinder_Core, LmGuide_Core, …) just append it to the list
# AND add a maincategory row whose `db_file_name` points to it. The
# proxy auto-discovers everything else.
PG_DATABASES=Standard_Core,Motor_Core

# The "primary" DB holds the canonical category tables (maincategory,
# subcategory, midcategory, parttype). New categories register
# themselves there too.
PG_PRIMARY_DB=Standard_Core

# Optional friendly aliases used by /diag/* endpoints (?db=std).
# Format: alias:realName,alias:realName
PG_DB_ALIASES=std:Standard_Core,motor:Motor_Core

# ─────────────────────────────────────────────────────────
# Pool tuning
# ─────────────────────────────────────────────────────────
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=5000
PG_SSL=false

LOG_LEVEL=pretty

# ─────────────────────────────────────────────────────────
# CAD backend selection
# ─────────────────────────────────────────────────────────
# hand — hand-written AP214 STEP writer (default; no WASM load;
#        multi-shell geometry; 2 ms/request)
# occt — opencascade.js WASM (first request ~700 ms warmup, then
#        ~70 ms; single fused solid with real chamfers/fillets)
#
# The flag only affects STEP output — DXF is always hand-written.
# CAD_BACKEND=hand

# Cut real smooth helical thread grooves when CAD_BACKEND=occt.
# Costs 5–15 s on a cold request (hot cache is free). Only meaningful
# for Hex-family heads; other head kinds ignore it.
# OCCT_REAL_THREAD=true

# When OCCT produces a degenerate shape, dump the failing STEP bytes
# to %TEMP%\bolt-occt-debug-<partCode>-<tag>-<ts>.stp for inspection.
# The hand-written fallback is served to the user regardless.
# OCCT_DEBUG_DUMP=true
